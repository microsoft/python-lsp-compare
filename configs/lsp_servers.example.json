{
  "version": 1,
  "baselineServer": "pyright",
  "servers": [
    {
      "id": "pyright",
      "displayName": "Pyright",
      "enabled": true,
      "kind": "node-wrapper",
      "sourcePath": "C:/path/to/pyright/packages/pyright/langserver.index.js",
      "launch": {
        "command": "C:/Program Files/nodejs/node.exe",
        "args": [
          "C:/path/to/pyright/packages/pyright/langserver.index.js",
          "--stdio"
        ]
      },
      "notes": [
        "Copy this file to .python-lsp-compare/lsp_servers.json and replace placeholder paths.",
        "Pyright supports --stdio natively, no wrapper needed."
      ]
    },
    {
      "id": "ty",
      "displayName": "Ty",
      "enabled": true,
      "kind": "native-exe",
      "sourcePath": "C:/path/to/ty.exe",
      "launch": {
        "command": "C:/path/to/ty.exe",
        "args": [
          "server"
        ]
      },
      "notes": [
        "Ty uses the `server` subcommand for LSP."
      ]
    },
    {
      "id": "pyrefly",
      "displayName": "Pyrefly",
      "enabled": true,
      "kind": "native-exe",
      "sourcePath": "C:/path/to/pyrefly.exe",
      "launch": {
        "command": "C:/path/to/pyrefly.exe",
        "args": [
          "lsp",
          "--indexing-mode",
          "lazy-blocking",
          "--build-system-blocking"
        ]
      },
      "notes": [
        "Pyrefly is typically launched with `lsp --indexing-mode lazy-blocking --build-system-blocking`.",
        "If a server truly needs different arguments for benchmarks only, use launch.benchmarkArgs as an optional advanced field."
      ]
    }
  ]
}